# backend/.env.example

# Flask app config
FLASK_ENV=production
PORT=5000

# JWT config
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRY_HOURS=12

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/geniqx_db

# CORS allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000
