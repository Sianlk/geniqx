{
  "expo": {
    "name": "GeniQX",
    "slug": "geniqx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "geniqx",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ECFEFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sianlk.geniqx",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for profile photo and document scanning.",
        "NSMicrophoneUsageDescription": "Used for voice consultations and AI commands.",
        "NSFaceIDUsageDescription": "Used for secure biometric authentication.",
        "NSPhotoLibraryUsageDescription": "Used to upload profile photos.",
        "NSLocationWhenInUseUsageDescription": "Used to find nearby services."
      },
      "associatedDomains": [
        "applinks:geniqx.sianlk.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ECFEFF"
      },
      "package": "com.sianlk.geniqx",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "geniqx.sianlk.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#06B6D4"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera."
        }
      ],
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "extra": {
      "apiBaseUrl": "https://api.geniqx.sianlk.com",
      "appEnv": "production",
      "eas": {
        "projectId": "sianlk-geniqx"
      }
    },
    "owner": "sianlk",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/sianlk-geniqx",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    }
  }
}