⚙️ Launch sovereign GENIQX chain (no gas, no ETH, own node)
0x11a2357d37fa2a6da113412ed41b2f86b6629348// SPDX-License-Identifier: MIT
pragma solidity ^0.8.24;
contract GeniqxNFT {
    uint256 public tokenCount = 0;
    struct NFT {
        address owner;
        string metadataURI;
    }
    mapping(uint256 => NFT) public nfts;
    event Minted(address indexed to, uint256 indexed tokenId, string uri);
    function mint(address to, string memory uri) public returns (uint256) {
        tokenCount++;
        nfts[tokenCount] = NFT(to, uri);
        emit Minted(to, tokenCount, uri);
        return tokenCount;
    }
    function getNFT(uint256 id) public view returns (address, string memory) {
        NFT memory nft = nfts[id];
        return (nft.owner, nft.metadataURI);
    }
}
